{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Experience": {
      "title": "Experience",
      "description": "A professional experience entry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "tech": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "company", "location", "date", "highlights", "tech"]
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } },
        "github": { "type": "string" },
        "githubIcon": { "type": "string" },
        "external": { "type": "string" },
        "externalIcon": { "type": "string" },
        "externalName": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "description", "tech"]
    },
    "SkillCategory": {
      "title": "Skill Category",
      "description": "A group of skills",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "iconName": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "iconName", "skills"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages submitted from the Contact form"
    },
    "/experiences/{experienceId}": {
      "schema": { "$ref": "#/entities/Experience" },
      "description": "Portfolio experiences"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Portfolio projects"
    },
    "/skills/{skillId}": {
      "schema": { "$ref": "#/entities/SkillCategory" },
      "description": "Portfolio skills categories"
    }
  }
}
